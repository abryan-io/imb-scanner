# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is tracked as a template.

# ---------- Cloudflare R2 (failed scan storage) ----------
# Dashboard: https://dash.cloudflare.com → R2
# Account ID: shown on the R2 overview page (right sidebar)
# Access keys: R2 → Manage API Tokens → Create API Token (scope to your bucket, read+write)
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=imb-failed-scans
# Endpoint is https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://your-account-id-here.r2.cloudflarestorage.com

# ---------- Failed scan backend switch ----------
# local = write to FAILED_SCAN_LOCAL_PATH on disk (for dev)
# r2    = write to the R2 bucket above (for Streamlit Cloud)
# off   = do not capture failed scans
FAILED_SCAN_BACKEND=local
FAILED_SCAN_LOCAL_PATH=./data/failed_scans

# ---------- Logging ----------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
